# --- OpenBeats environment configuration ---
# Copy this file to .env and adjust the values for your setup.

# HTTP port the API server listens on.
PORT=8080

# PostgreSQL connection string (pgx/libpq format).
# For docker-compose the host is the "postgres" service.
DATABASE_URL=postgres://openbeats:openbeats@postgres:5432/openbeats?sslmode=disable

# Secret used to sign JWT access tokens. MUST be set to a long random value
# in production. Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-please-use-a-long-random-secret

# Lifetime of issued JWT access tokens.
JWT_TTL=24h

# Absolute path (inside the container) to the persistent volume that stores
# the uploaded audio files and extracted cover images.
STORAGE_PATH=/data

# Bootstrap admin user. On first start (when the users table is empty) an admin
# account is created with these credentials so you can log in and register
# further users via POST /api/auth/register.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Comma-separated list of allowed CORS origins for the browser frontend.
# Use * to allow all origins (development only).
CORS_ORIGINS=*
